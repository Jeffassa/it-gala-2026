SECRET_KEY=change-me-in-prod-openssl-rand-hex-32
DATABASE_URL=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ACCESS_TOKEN_EXPIRE_MINUTES=720

# URL publique du frontend (utilisée dans les liens de reset password)
FRONTEND_URL=http://localhost:5173

# ───────── EMAIL ─────────
# Le code choisit automatiquement le transport :
#   1) Resend (si RESEND_API_KEY défini)   ← RECOMMANDÉ EN PROD (Render Free)
#   2) SMTP   (si MAIL_HOST défini sans Resend) ← bloqué sur Render Free
#   3) Console (sinon, dev only) ← affiche l'email dans les logs

# ─── Resend (production) ───
# 1. Créer un compte sur https://resend.com
# 2. Générer une clé sur https://resend.com/api-keys (commence par "re_")
# 3. Pour envoyer à n'importe quel email → vérifier un domaine sur https://resend.com/domains
#    Sinon (compte gratuit non vérifié) tu ne peux envoyer qu'à l'email du compte Resend.
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME=IT Gala 2026

# ─── SMTP (dev local uniquement) ───
# MailHog  : MAIL_HOST=localhost MAIL_PORT=1025 MAIL_TLS=false (UI: http://localhost:8025)
# Gmail    : MAIL_HOST=smtp.gmail.com MAIL_PORT=587 MAIL_TLS=true + app password
# SendGrid : MAIL_HOST=smtp.sendgrid.net MAIL_PORT=587 MAIL_TLS=true MAIL_USERNAME=apikey MAIL_PASSWORD=<key>
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_TLS=true
MAIL_DEBUG=true
